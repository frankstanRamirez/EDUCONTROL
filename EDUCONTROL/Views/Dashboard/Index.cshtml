@{
    ViewData["Title"] = "Dashboard";
    var rol = Context.Session.GetString("UsuarioRol") ?? "";
}

<div class="container-fluid mt-4">
    <h4 class="mb-4 fw-bold">
        <i class="bi bi-speedometer2 text-primary"></i> Panel de Control
    </h4>

    @if (rol == "Director" || rol == "Secretaria")
    {
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="stat-card shadow-sm border-0 bg-primary-grad">
                    <div class="stat-content">
                        <div class="stat-info">
                            <span class="lbl">Alumnos activos</span>
                            <h2 class="num">@ViewBag.TotalAlumnos</h2>
                        </div>
                        <i class="bi bi-people-fill icon"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="stat-card shadow-sm border-0 bg-dark-grad">
                    <div class="stat-content">
                        <div class="stat-info">
                            <span class="lbl">Usuarios activos</span>
                            <h2 class="num">@ViewBag.TotalUsuarios</h2>
                        </div>
                        <i class="bi bi-person-badge-fill icon"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="stat-card shadow-sm border-0 bg-orange-grad">
                    <div class="stat-content">
                        <div class="stat-info">
                            <span class="lbl">Notas registradas</span>
                            <h2 class="num">@ViewBag.TotalNotas</h2>
                        </div>
                        <i class="bi bi-pencil-fill icon"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="stat-card shadow-sm border-0 bg-success-grad">
                    <div class="stat-content">
                        <div class="stat-info">
                            <span class="lbl">Presentes hoy</span>
                            <h2 class="num">@ViewBag.AsistenciasHoy</h2>
                        </div>
                        <i class="bi bi-calendar-check-fill icon"></i>
                    </div>
                </div>
            </div>
        </div>
    }


    @if (rol == "Profesor")
    {
        <div class="d-flex align-items-center gap-2 mb-4">
            <h5 class="mb-0 text-muted me-2">Estás viendo:</h5>

            <span class="badge bg-secondary px-3 py-2" style="font-size: 0.9rem; border-radius: 6px;">
                @ViewBag.Grado
            </span>

            @if (ViewBag.Seccion != null)
            {
                <span class="badge bg-success px-3 py-2" style="font-size: 0.9rem; border-radius: 6px;">
                    Sección @ViewBag.Seccion
                </span>
            }
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="stat-card shadow-sm bg-primary-grad">
                    <div class="stat-content">
                        <div class="stat-info">
                            <span class="lbl">Alumnos en mi grado</span>
                            <h2 class="num">@ViewBag.TotalAlumnos</h2>
                        </div>
                        <i class="bi bi-people-fill icon"></i>
                    </div>
                </div>
            </div>

        </div>
    }

    <h6 class="text-muted fw-bold mb-3 uppercase small" style="letter-spacing: 1px;">Accesos rápidos</h6>
    <div class="d-flex flex-wrap gap-2">
        <a asp-controller="Asistencia" asp-action="Registrar" class="btn btn-white shadow-sm border px-3">
            <i class="bi bi-calendar-plus text-primary"></i> Registrar asistencia
        </a>
        <a asp-controller="Notas" asp-action="Registrar" class="btn btn-white shadow-sm border px-3">
            <i class="bi bi-plus-circle text-primary"></i> Registrar nota
        </a>
        @if (rol == "Director" || rol == "Secretaria")
        {
            <a asp-controller="Alumnos" asp-action="Create" class="btn btn-white shadow-sm border px-3">
                <i class="bi bi-person-plus text-success"></i> Nuevo alumno
            </a>
            <a asp-controller="Reportes" asp-action="Asistencia" class="btn btn-white shadow-sm border px-3">
                <i class="bi bi-file-earmark-bar-graph text-secondary"></i> Ver reportes
            </a>
        }
    </div>
</div>

<style>
    /* Estilos para las tarjetas profesionales */
    .stat-card {
        padding: 1.5rem;
        border-radius: 12px;
        color: white;
        transition: transform 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .stat-card:hover {
            transform: translateY(-5px);
        }

    .stat-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .stat-info .lbl {
        display: block;
        font-size: 0.85rem;
        text-transform: uppercase;
        font-weight: 600;
        opacity: 0.8;
        margin-bottom: 5px;
    }

    .stat-info .num {
        font-size: 2rem;
        font-weight: 800;
        margin: 0;
    }

    .stat-card .icon {
        font-size: 2.5rem;
        opacity: 0.3;
    }

    /* Degradados modernos */
    .bg-primary-grad {
        background: linear-gradient(45deg, #2E75B6, #4b92d4);
    }

    .bg-dark-grad {
        background: linear-gradient(45deg, #1F3864, #34568b);
    }

    .bg-orange-grad {
        background: linear-gradient(45deg, #fd7e14, #ff9e42);
    }

    .bg-success-grad {
        background: linear-gradient(45deg, #28a745, #4cd169);
    }

    /* Botones de accesos rápidos estilo "Clean" */
    .btn-white {
        background: white;
        color: #444;
        font-weight: 500;
        border-radius: 8px;
    }

        .btn-white:hover {
            background: #f8f9fa;
            color: #000;
        }
</style>