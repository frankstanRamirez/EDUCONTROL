@model IEnumerable<EDUCONTROL.Models.Alumno>
@{
    ViewData["Title"] = "Alumnos";
}
@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Alumnos registrados</h2>
    <a asp-action="Create" class="btn btn-primary">+ Nuevo alumno</a>
</div>
<div class="row mb-3">
    <div class="col-md-3 bg-light rounded p-3 me-2 text-center">
        <small class="text-muted">Total inscritos</small>
        <div class="fs-3 fw-semibold">@ViewBag.Total</div>
    </div>
    <div class="col-md-3 bg-light rounded p-3 text-center">
        <small class="text-muted">Activos</small>
        <div class="fs-3 fw-semibold text-success">@ViewBag.Activos</div>
    </div>
</div>
<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input name="buscar" value="@ViewBag.Buscar" class="form-control"
               placeholder="Buscar por NIE o nombre..." />
    </div>
    <div class="col-md-3">
        <select name="grado" class="form-select">
            <option value="">-- Todos los grados --</option>
            @foreach (var g in new[]{"1 grado","2 grado","3 grado","4 grado","5 grado","6 grado","7 grado","8 grado","9 grado"})
            {
            <option value="@g" selected="@(ViewBag.GradoFiltro == g)">@g</option> }
        </select>
    </div>
    <div class="col-md-2">
        <select name="estado" class="form-select">
            <option value="">Todos</option>
            <option value="Activo"
                selected="@(ViewBag.EstadoFiltro == "Activo")">Activo</option>
            <option value="Inactivo"
                    selected="@(ViewBag.EstadoFiltro == "Inactivo")">Inactivo</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100">Filtrar</button>
    </div>
    <div class="col-md-1">
        <a asp-action="Index" class="btn btn-outline-secondary w-100">X</a>
    </div>
</form>
<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th>NIE</th>
            <th>Nombre completo</th>
            <th>Grado</th>
            <th>Anio</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var a in Model)
                {
                    <tr>
                        <td><code>@a.NIE</code></td>
                        <td>@a.NombreCompleto</td>
                        <td>@a.Grado</td>
                        <td>@a.AnioAcademico</td>
                        <td>
                            <span class="badge @(a.Estado == "Activo" ? "bg-success" : "bgdanger")">@a.Estado</span>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-outlinewarning">Editar</a>
                            <a asp-action="Delete" asp-route-id="@a.Id" class="btn btn-sm btnoutline-danger">Eliminar</a>
                        </td>
                    </tr>
                }
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted">
                    No se encontraron
                    alumnos.
                </td>
            </tr>
        }
    </tbody>
</table>
