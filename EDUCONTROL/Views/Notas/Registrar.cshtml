@model EDUCONTROL.Models.Nota
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Registrar Nota";
    var asignaturas = ViewBag.Asignaturas as List<EDUCONTROL.Models.Asignatura>;
    var alumnos = ViewBag.Alumnos as List<EDUCONTROL.Models.Alumno>;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center gap-2">
        <a asp-action="Index" asp-controller="Dashboard" class="btn btn-outline-secondary btn-sm shadow-sm">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h4 class="fw-bold mb-0">Registrar Nota</h4>
    </div>

    <a asp-action="Consultar"
       asp-controller="Notas"
       asp-route-grado="@Context.Session.GetString("GradoAsignado")"
       asp-route-seccion="@Context.Session.GetString("SeccionAsignada")"
       class="btn btn-outline-secondary shadow-sm">
        <i class="bi bi-list-task me-2"></i> Ver Historial
    </a>
</div>

<div class="card shadow-sm border-0" style="max-width:620px; border-radius: 12px;">
    <div class="card-body p-4">
        <form asp-action="Registrar" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3 position-relative">
                <label class="form-label fw-semibold">Buscar alumno</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="buscadorAlumno" class="form-control border-start-0 shadow-sm"
                           placeholder="Escribe nombre o apellido..." autocomplete="off" />
                </div>
                <div id="listaAlumnos" class="list-group mt-1 shadow"
                     style="max-height:200px; overflow-y:auto; display:none; z-index:1000; position:absolute; width: 100%;"></div>

                <input type="hidden" name="AlumnoId" id="alumnoIdHidden" value="@Model?.AlumnoId" />
                <div id="alumnoSeleccionado" class="mt-2 text-success fw-bold"></div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Asignatura</label>
                <select name="AsignaturaId" class="form-select shadow-sm" required>
                    <option value="">-- Seleccionar asignatura --</option>
                    @if (asignaturas != null)
                    {
                        @foreach (var s in asignaturas)
                        {
                            <option value="@s.Id">@s.Nombre</option>
                        }
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Periodo a registrar</label>
                <select id="periodoSelector" class="form-select shadow-sm" onchange="mostrarPeriodo()">
                    <option value="1">Periodo 1</option>
                    <option value="2">Periodo 2</option>
                    <option value="3">Periodo 3</option>
                </select>
            </div>

            <div class="mb-4">
                <label id="labelNota" class="form-label fw-semibold">Nota — Periodo 1</label>
                <input type="number" id="notaInput" step="0.1" min="0" max="10"
                       class="form-control shadow-sm" style="max-width:180px"
                       placeholder="0.0 — 10.0" required />

                <input type="hidden" name="Periodo1" id="p1" value="" />
                <input type="hidden" name="Periodo2" id="p2" value="" />
                <input type="hidden" name="Periodo3" id="p3" value="" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4 shadow-sm" onclick="prepararPeriodos()">
                    <i class="bi bi-save me-2"></i> Guardar nota
                </button>
                <a asp-action="Index" asp-controller="Dashboard" class="btn btn-light border px-4 shadow-sm">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const alumnos = [
            @if (alumnos != null)
            {
                    @foreach (var a in alumnos)
                    {
                            @Html.Raw($"{{ id: {a.Id}, nombre: '{a.NombreCompleto.Replace("'", "\\'")} ({a.Grado})' }},")
                    }
            }
        ];

        const buscador = document.getElementById('buscadorAlumno');
        const lista = document.getElementById('listaAlumnos');
        const hiddenId = document.getElementById('alumnoIdHidden');
        const selecLabel = document.getElementById('alumnoSeleccionado');

        buscador.addEventListener('input', function () {
            const q = this.value.toLowerCase().trim();
            lista.innerHTML = '';
            if (q.length < 2) { lista.style.display = 'none'; return; }

            const resultados = alumnos.filter(a => a.nombre.toLowerCase().includes(q));
            if (resultados.length === 0) {
                lista.style.display = 'none'; return;
            }

            resultados.forEach(a => {
                const item = document.createElement('button');
                item.type = 'button';
                item.className = 'list-group-item list-group-item-action';
                item.textContent = a.nombre;
                item.onclick = () => {
                    hiddenId.value = a.id;
                    buscador.value = a.nombre;
                    selecLabel.textContent = '✔ ' + a.nombre;
                    lista.style.display = 'none';
                };
                lista.appendChild(item);
            });
            lista.style.display = 'block';
        });

        document.addEventListener('click', e => {
            if (!buscador.contains(e.target)) lista.style.display = 'none';
        });

        function mostrarPeriodo() {
            const p = document.getElementById('periodoSelector').value;
            document.getElementById('labelNota').textContent = 'Nota — Periodo ' + p;
            document.getElementById('notaInput').value = '';
        }

        function prepararPeriodos() {
            const p = document.getElementById('periodoSelector').value;
            const nota = document.getElementById('notaInput').value;
            document.getElementById('p1').value = p === '1' ? nota : '';
            document.getElementById('p2').value = p === '2' ? nota : '';
            document.getElementById('p3').value = p === '3' ? nota : '';
        }
    </script>
}