@model IEnumerable<EDUCONTROL.Models.Alumno>
@{
    ViewData["Title"] = "Consultar Notas";
    bool esAdmin = ViewBag.EsAdmin == true;
    int? asigId = ViewBag.AsigFiltro as int?;
    var listaMaterias = ViewBag.Asignaturas as List<EDUCONTROL.Models.Asignatura>;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="fw-bold mb-0">
        <i class="bi bi-journal-check text-primary"></i> Control de Notas
    </h2>
    <a asp-action="Registrar" class="btn btn-primary shadow-sm" style="border-radius: 10px;">
        <i class="bi bi-plus-circle me-1"></i> Registrar nueva nota
    </a>
</div>

@* --- PANEL DE FILTROS HÍBRIDO (mismo estilo que Asistencia) --- *@
<div class="card border-0 shadow-sm mb-4" style="background-color: #f8f9fa; border-radius: 15px;">
    <div class="card-body p-3">
        <form method="get" class="row g-3 align-items-end">

            @if (esAdmin)
            {
                @* VISTA PARA ADMIN/DIRECTOR: Selectores con estilo Píldora *@
                <div class="col-md-3">
                    <label class="small fw-bold text-muted d-block mb-1 text-uppercase">Grado</label>
                    <div class="input-group bg-white shadow-sm border" style="border-radius: 25px; overflow: hidden; height: 45px;">
                        <span class="input-group-text bg-white border-0 pe-1"><i class="bi bi-mortarboard text-primary"></i></span>
                        <select name="grado" class="form-select border-0 fw-bold" style="box-shadow: none; font-size: 0.9rem;">
                            <option value="">-- Todos los grados --</option>
                            @foreach (var g in new[] { "1 grado", "2 grado", "3 grado", "4 grado", "5 grado", "6 grado", "7 grado", "8 grado", "9 grado" })
                            {
                                <option value="@g" selected="@(ViewBag.GradoFiltro == g)">@g</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="col-md-2">
                    <label class="small fw-bold text-muted d-block mb-1 text-uppercase">Sección</label>
                    <div class="input-group bg-white shadow-sm border" style="border-radius: 25px; overflow: hidden; height: 45px;">
                        <span class="input-group-text bg-white border-0 pe-1"><i class="bi bi-collection text-primary"></i></span>
                        <select name="seccion" class="form-select border-0 fw-bold text-primary" style="box-shadow: none; font-size: 0.9rem;">
                            <option value="">Sec</option>
                            @foreach (var s in new[] { "A", "B", "C", "D" })
                            {
                                <option value="@s" selected="@(ViewBag.SeccionFiltro == s)">@s</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="small fw-bold text-muted d-block mb-1 text-uppercase">Materia</label>
                    <div class="input-group bg-white shadow-sm border" style="border-radius: 25px; overflow: hidden; height: 45px;">
                        <span class="input-group-text bg-white border-0 pe-1"><i class="bi bi-book text-primary"></i></span>
                        <select name="asignaturaId" class="form-select border-0 fw-bold" style="box-shadow: none; font-size: 0.9rem;">
                            <option value="">-- Todas las materias --</option>
                            @foreach (var asig in listaMaterias)
                            {
                                <option value="@asig.Id" selected="@(asigId == asig.Id)">@asig.Nombre</option>
                            }
                        </select>
                    </div>
                </div>
            }
            else
            {
                @* VISTA PARA PROFESOR: Mi Sección fija + selector de materia *@
                <div class="col-md-auto">
                    <label class="small fw-bold text-muted d-block mb-1 text-uppercase">Mi Sección</label>
                    <div class="bg-white d-flex align-items-center px-3 shadow-sm border" style="border-radius: 25px; height: 45px;">
                        <i class="bi bi-people-fill text-primary me-2"></i>
                        <span class="fw-bold text-dark">@ViewBag.GradoFiltro "@ViewBag.SeccionFiltro"</span>
                    </div>
                    <input type="hidden" name="grado" value="@ViewBag.GradoFiltro" />
                    <input type="hidden" name="seccion" value="@ViewBag.SeccionFiltro" />
                </div>

                <div class="col-md-4">
                    <label class="small fw-bold text-muted d-block mb-1 text-uppercase">Materia</label>
                    <div class="input-group bg-white shadow-sm border" style="border-radius: 25px; overflow: hidden; height: 45px;">
                        <span class="input-group-text bg-white border-0 pe-1"><i class="bi bi-book text-primary"></i></span>
                        <select name="asignaturaId" class="form-select border-0 fw-bold" style="box-shadow: none; font-size: 0.9rem;" onchange="this.form.submit()">
                            <option value="">-- Seleccionar Materia --</option>
                            @foreach (var asig in listaMaterias)
                            {
                                <option value="@asig.Id" selected="@(asigId == asig.Id)">@asig.Nombre</option>
                            }
                        </select>
                    </div>
                </div>
            }

            @* Botones de Acción *@
            <div class="col-md-auto ms-auto d-flex gap-2">
                <button type="submit" class="btn btn-dark px-4 shadow-sm" style="border-radius: 12px; height: 45px;">
                    <i class="bi bi-funnel me-1"></i> Filtrar
                </button>
                <a asp-action="Consultar" class="btn btn-outline-secondary shadow-sm d-flex align-items-center justify-content-center" style="border-radius: 12px; width: 45px; height: 45px;">
                    <i class="bi bi-arrow-clockwise"></i>
                </a>
            </div>

        </form>
    </div>
</div>

@* --- TABLA DE RESULTADOS --- *@
<div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead style="background-color: #f8f9fa;">
                <tr class="text-muted small">
                    <th class="ps-4 text-uppercase">Alumno</th>
                    @if (esAdmin)
                    {
                        <th class="text-center text-uppercase">Grado/Sec</th>
                    }
                    <th class="text-uppercase">Asignatura</th>
                    <th class="text-center text-uppercase">P1</th>
                    <th class="text-center text-uppercase">P2</th>
                    <th class="text-center text-uppercase">P3</th>
                    <th class="text-center text-uppercase">Promedio</th>
                    <th class="text-center text-uppercase">Estado</th>
                    <th class="text-center pe-4 text-uppercase">Acción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var alu in Model)
                {
                    var nota = alu.Notas?.FirstOrDefault(n => n.AsignaturaId == asigId);

                    <tr style="border-bottom: 1px solid #f2f2f2;">
                        <td class="ps-4">
                            <div class="fw-bold text-dark" style="font-size: 0.95rem;">@alu.NombreCompleto</div>
                            <div class="text-muted small" style="font-size: 0.8rem;">ID: @alu.Id</div>
                        </td>

                        @if (esAdmin)
                        {
                            <td class="text-center">
                                <span class="text-muted" style="font-size: 0.9rem;">@alu.Grado - @alu.Seccion</span>
                            </td>
                        }

                        <td>
                            @if (asigId != null)
                            {
                                <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle">
                                    @listaMaterias.FirstOrDefault(a => a.Id == asigId)?.Nombre
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small fst-italic">Seleccione materia</span>
                            }
                        </td>

                        <td class="text-center">@(nota?.Periodo1?.ToString("0.0") ?? "—")</td>
                        <td class="text-center">@(nota?.Periodo2?.ToString("0.0") ?? "—")</td>
                        <td class="text-center">@(nota?.Periodo3?.ToString("0.0") ?? "—")</td>

                        <td class="text-center">
                            <span class="fs-6 fw-bold @(nota?.Promedio >= 6 ? "text-success" : "text-danger")">
                                @(nota?.Promedio.ToString("0.0") ?? "0.0")
                            </span>
                        </td>

                        <td class="text-center">
                            @if (nota != null)
                            {
                                @if (nota.Promedio >= 6)
                                {
                                    <span class="badge rounded-pill bg-success px-3 py-2" style="font-size: 0.75rem; min-width: 90px;">
                                        <i class="bi bi-check-circle-fill me-1"></i> Aprobado
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-danger px-3 py-2" style="font-size: 0.75rem; min-width: 90px;">
                                        <i class="bi bi-x-circle-fill me-1"></i> Reprobado
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-light text-muted border px-3 py-2" style="font-size: 0.75rem; min-width: 90px;">
                                    Pendiente
                                </span>
                            }
                        </td>

                        <td class="text-center pe-4">
                            @if (nota != null)
                            {
                                <a asp-action="Edit" asp-route-id="@nota.Id" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm">
                                    <i class="bi bi-pencil-square me-1"></i> Editar
                                </a>
                            }
                            else
                            {
                                <a asp-action="Registrar" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                    <i class="bi bi-plus me-1"></i> Nota
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>