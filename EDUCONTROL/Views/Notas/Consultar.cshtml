@model IEnumerable<EDUCONTROL.Models.Nota>
@{
    ViewData["Title"] = "Consultar Notas";
    bool esAdmin = ViewBag.EsAdmin == true;
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0">
        <i class="bi bi-journal-check text-primary"></i> Consultar Notas
    </h2>
    <a asp-action="Registrar" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-circle"></i> + Registrar nota
    </a>
</div>

@* --- FILTROS: Solo para Director/Secretaria --- *@
@if (esAdmin)
{
    <div class="card bg-light border-0 mb-4">
        <div class="card-body">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="small fw-bold text-muted">Grado</label>
                    <select name="grado" class="form-select">
                        <option value="">-- Todos los grados --</option>
                        @foreach (var g in new[] { "1 grado", "2 grado", "3 grado", "4 grado", "5 grado", "6 grado", "7 grado", "8 grado", "9 grado" })
                        {
                            <option value="@g" selected="@(ViewBag.GradoFiltro == g)">@g</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="small fw-bold text-muted">Sección</label>
                    <select name="seccion" class="form-select">
                        <option value="">-- Todas --</option>
                        @foreach (var s in new[] { "A", "B", "C", "D" })
                        {
                            <option value="@s" selected="@(ViewBag.SeccionFiltro == s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="small fw-bold text-muted">Materia / Asignatura</label>
                    <select name="asignaturaId" class="form-select">
                        <option value="">-- Todas las materias --</option>
                        @if (ViewBag.Asignaturas is List<EDUCONTROL.Models.Asignatura> listaAsig)
                        {
                            @foreach (var asig in listaAsig)
                            {
                                <option value="@asig.Id" selected="@(ViewBag.AsigFiltro == asig.Id)">@asig.Nombre</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-funnel"></i> Filtrar
                    </button>
                </div>
                <div class="col-md-1">
                    <a asp-action="Consultar" class="btn btn-outline-secondary w-100" title="Limpiar">
                        <i class="bi bi-x-lg"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>
}
else
{
    @* El profesor solo ve qué está consultando *@
    <div class="alert alert-info border-0 shadow-sm d-flex align-items-center">
        <i class="bi bi-info-circle-fill me-2 fs-5"></i>
        <span>Consulta para: <strong>@ViewBag.GradoFiltro "@ViewBag.SeccionFiltro"</strong></span>
    </div>
}

@* --- TABLA DE RESULTADOS --- *@
<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Alumno</th>
                    <th class="text-center">Grado/Sec</th>
                    <th>Asignatura</th>
                    <th class="text-center">P1</th>
                    <th class="text-center">P2</th>
                    <th class="text-center">P3</th>
                    <th class="text-center">Promedio</th>
                    <th class="text-center">Estado</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    @foreach (var n in Model)
                    {
                        <tr>
                            <td class="fw-semibold text-dark">@(n.Alumno?.NombreCompleto ?? "N/A")</td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border">
                                    @(n.Alumno?.Grado ?? "S/G") - @(n.Alumno?.Seccion ?? "S/S")
                                </span>
                            </td>
                            <td>@(n.Asignatura?.Nombre ?? "N/A")</td>
                            <td class="text-center text-muted">@(n.Periodo1?.ToString("0.0") ?? "—")</td>
                            <td class="text-center text-muted">@(n.Periodo2?.ToString("0.0") ?? "—")</td>
                            <td class="text-center text-muted">@(n.Periodo3?.ToString("0.0") ?? "—")</td>
                            <td class="text-center"><strong class="fs-6">@n.Promedio.ToString("0.0")</strong></td>
                            <td class="text-center">
                                @if (n.Estado == "Aprobado")
                                {
                                    <span class="badge bg-success">
                                        <i class="bi bi-check-circle-fill me-1"></i> @n.Estado
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        <i class="bi bi-x-circle-fill me-1"></i> @n.Estado
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                }

                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">
                            <i class="bi bi-search" style="font-size: 2rem;"></i>
                            <p class="mt-2 mb-0">No se encontraron registros con los filtros seleccionados.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>