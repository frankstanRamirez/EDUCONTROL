@{
    var rol = Context.Session.GetString("UsuarioRol") ?? "";
    var nombre = Context.Session.GetString("UsuarioNombre") ?? "Usuario";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EDUCONTROL — @ViewData["Title"]</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrapicons.css" />

    <style>
        body {
            display: flex;
            min-height: 100vh;
            background: #f4f6f9;
        }
        /* ── SIDEBAR ── */
        #sidebar {
            width: 240px;
            min-height: 100vh;
            background: #1F3864;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 100;
            display: flex;
            flex-direction: column;
        }

            #sidebar .logo-area {
                padding: 20px 16px;
                border-bottom: 1px solid rgba(255,255,255,.15);
            }

                #sidebar .logo-area img {
                    height: 48px;
                }

            #sidebar .nav-link {
                color: rgba(255,255,255,.75);
                padding: 10px 20px;
                border-radius: 6px;
                margin: 2px 8px;
                display: flex;
                align-items: center;
                gap: 10px;
                font-size: .95rem;
            }

                #sidebar .nav-link:hover,
                #sidebar .nav-link.active {
                    color: #fff;
                    background: rgba(255,255,255,.15);
                }

            #sidebar .nav-section {
                font-size: .7rem;
                text-transform: uppercase;
                letter-spacing: .08em;
                color: rgba(255,255,255,.4);
                padding: 14px 20px 4px;
            }

        /* ── CONTENIDO ── */
        #main {
            margin-left: 240px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        #topnav {
            background: #fff;
            border-bottom: 1px solid #dee2e6;
            padding: 0 24px;
            height: 56px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 99;
        }

        #content {
            padding: 28px 28px;
        }
        /* ── CARDS DEL DASHBOARD ── */
        .stat-card {
            border: none;
            border-radius: 12px;
            padding: 20px;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 16px;
        }

            .stat-card .icon {
                font-size: 2.2rem;
                opacity: .8;
            }

            .stat-card .num {
                font-size: 2rem;
                font-weight: 700;
                line-height: 1;
            }

            .stat-card .lbl {
                font-size: .85rem;
                opacity: .85;
            }

        @@media (max-width:768px) {
            #sidebar {
                transform: translateX(-100%);
            }

            #main {
                margin-left: 0;
            }
        }
    </style>
</head>
<body>


    <!-- ══ SIDEBAR ════════════════════════════════════════════════════ -->
    <nav id="sidebar">
        <!-- Logo -->
        <div class="logo-area text-center">
            <img src="~/images/logo.png" alt="EduControl"
                 style="height:100px; width:auto;" />
        </div>
        <!-- Menu dinamico segun rol -->
        <div class="mt-2 flex-grow-1">
            <!-- Dashboard: todos los roles -->
            <div class="nav-section">General</div>
            <a asp-controller="Dashboard" asp-action="Index"
               class="nav-link
@(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <!-- Modulos solo para Director y Secretaria -->
            @if (rol == "Director" || rol == "Secretaria")
            {
                <div class="nav-section">Academico</div>
                <a asp-controller="Alumnos" asp-action="Index"
                   class="nav-link
        @(ViewContext.RouteData.Values["controller"]?.ToString() == "Alumnos" ? "active" : "")">
                    <i class="bi bi-people"></i> Alumnos
                </a>
                <a asp-controller="Asignaturas" asp-action="Index"
                   class="nav-link
        @(ViewContext.RouteData.Values["controller"]?.ToString() == "Asignaturas" ? "active" : "")">
                    <i class="bi bi-journal-bookmark"></i> Asignaturas
                </a>
            }

            <!-- Notas y Asistencia: todos los roles -->
            @if (rol != "")
            {
                @if (rol != "Director" && rol != "Secretaria")
                {
                    <div class="nav-section">Mi grado</div>
                }
                <a asp-controller="Asistencia" asp-action="Registrar"
                   class="nav-link
        @(ViewContext.RouteData.Values["controller"]?.ToString() == "Asistencia" ? "active" : "")">
                    <i class="bi bi-calendar-check"></i> Asistencia
                </a>
                <a asp-controller="Notas" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Notas" ? "active" : "")">
                    <i class="bi bi-pencil-square"></i> Notas
                </a>
            }

            <!-- Reportes: Director y Secretaria -->
            @if (rol == "Director" || rol == "Secretaria")
            {
                <div class="nav-section">Reportes</div>
                <a asp-controller="Reportes" asp-action="Asistencia"
                   class="nav-link">
                    <i class="bi bi-file-earmark-bar-graph"></i> Rep. Asistencia
                </a>
                <a asp-controller="Reportes" asp-action="Notas"
                   class="nav-link">
                    <i class="bi bi-file-earmark-text"></i> Rep. Notas
                </a>
            }

            <!-- Usuarios: solo Director -->
            @if (rol == "Director")
            {
                <div class="nav-section">Administracion</div>
                <a asp-controller="Usuarios" asp-action="Index"
                   class="nav-link
    @(ViewContext.RouteData.Values["controller"]?.ToString() == "Usuarios" ? "active" : "")">
                    <i class="bi bi-shield-lock"></i> Usuarios
                </a>
            }
        </div>
        <!-- Badge de rol en la parte inferior del sidebar -->
        <div class="p-3 border-top" style="border-color:rgba(255,255,255,.15)!important">
            <span class="badge
                 @(rol == "Director" ? "bg-danger" :
                   rol == "Secretaria" ? "bg-warning text-dark" : "bg-info text-dark") w-100 py-2">
                @rol
            </span>
        </div>
    </nav>

    <!-- ══ CONTENIDO PRINCIPAL ════════════════════════════════════════ -->
    <div id="main">
        <!-- Navbar superior -->
        <div id="topnav">
            <span class="fw-semibold text-secondary">@ViewData["Title"]</span>
            <div class="d-flex align-items-center gap-3">
                <span class="text-muted"><i class="bi bi-person-circle"></i> @nombre</span>
                <a asp-controller="Account" asp-action="Logout"
                   class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-box-arrow-right"></i> Salir
                </a>
            </div>
        </div>
        <!-- Alertas de exito -->
@if (TempData["OK"] != null)
{
            <div class="alert alert-success alert-dismissible fade show mx-4 mt-3">
                <i class="bi bi-check-circle"></i> @TempData["OK"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
}

        <!-- Contenido de cada pagina -->
        <div id="content">
            @RenderBody()
        </div>
    </div><!-- fin #main -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

