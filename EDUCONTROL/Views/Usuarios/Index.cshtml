@model IEnumerable<EDUCONTROL.Models.Usuario>
@{
    ViewData["Title"] = "Usuarios";
}

<style>
    /* Estilo del switch: Rojo (Inactivo) y Verde (Activo) */
    .form-check-input {
        background-color: #dc3545 !important; /* Rojo */
        border-color: #dc3545 !important;
        cursor: pointer;
        height: 1.25em !important; /* Tamaño estándar balanceado */
        width: 2.3em !important;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='-4 -4 8 8'%3e%3ccircle r='3' fill='white'/%3e%3c/svg%3e") !important;
    }

        .form-check-input:checked {
            background-color: #198754 !important; /* Verde */
            border-color: #198754 !important;
        }

    /* Contenedor para alinear los botones en la tabla */
    .acciones-contenedor {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    /* Color personalizado para el nombre de usuario (código) */
    .user-code {
        color: #d63384;
        font-family: SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-shield-lock text-primary"></i>
        Usuarios
    </h4>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-lg"></i> Nuevo usuario
    </a>
</div>

<div class="card shadow-sm border-0">
    <table class="table table-hover mb-0">
        <thead class="table-dark">
            <tr>
                <th class="ps-3">Nombre completo</th>
                <th>Usuario</th>
                <th>Rol</th>
                <th>Grado</th>
                <th>Estado</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td class="ps-3">@u.NombreCompleto</td>
                    <td><code class="user-code">@u.NombreUsuario</code></td>
                    <td>
                        <span class="badge @(u.Rol == "Director" ? "bg-danger" : u.Rol == "Secretaria" ? "bg-warning text-dark" : "bg-info")">
                            @u.Rol
                        </span>
                    </td>
                    <td>@(u.GradoAsignado ?? "—")</td>
                    <td>
                        <span class="badge @(u.Activo ? "bg-success" : "bg-secondary")">
                            @(u.Activo ? "Activo" : "Inactivo")
                        </span>
                    </td>
                    <td>
                        <div class="acciones-contenedor">
                            @* Botón Editar *@
                            <a asp-action="Edit" asp-route-id="@u.Id"
                               class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i>
                            </a>

                            @* Switch de Estado Automático *@
                            <form asp-action="ToggleActivo" asp-route-id="@u.Id" method="post" id="form-@u.Id" class="m-0">
                                @Html.AntiForgeryToken()
                                <div class="form-check form-switch p-0 m-0">
                                    <input class="form-check-input m-0" type="checkbox" role="switch"
                                           @(u.Activo ? "checked" : "")
                                           onchange="document.getElementById('form-@u.Id').submit();">
                                </div>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>