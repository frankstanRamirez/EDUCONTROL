@model IEnumerable<EDUCONTROL.Models.Usuario>
@{
    ViewData["Title"] = "Usuarios";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-shield-lock text-primary"></i>
        Usuarios
    </h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nuevo usuario
    </a>
</div>
<div class="card shadow-sm">
    <table class="table table-hover mb-0">
        <thead class="table-dark">
            <tr>
                <th>Nombre completo</th>
                <th>Usuario</th>
                <th>Rol</th>
                <th>Grado</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td>@u.NombreCompleto</td>
                    <td><code>@u.NombreUsuario</code></td>
                    <td>
                        <span class="badge
     @(u.Rol == "Director" ? "bg-danger" :
                               u.Rol == "Secretaria" ? "bg-warning text-dark" : "bg-info textdark")">
                            @u.Rol
                        </span>
                    </td>
                    <td>@(u.GradoAsignado ?? "—")</td>
                    <td>
                        <span class="badge @(u.Activo ? "bg-success" : "bg-secondary")">
                            @(u.Activo ? "Activo" : "Inactivo")
                        </span>
                    </td>
                    <td class="d-flex gap-1">
                        <a asp-action="Edit" asp-route-id="@u.Id"
                           class="btn btn-sm btn-outline-warning">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="ToggleActivo" asp-route-id="@u.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="btn btn-sm @(u.Activo ? "btn-outline-danger" : "btnoutline-success")">
                                <i class="bi @(u.Activo ? "bi-toggle-on" : "bi-toggleoff")"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>