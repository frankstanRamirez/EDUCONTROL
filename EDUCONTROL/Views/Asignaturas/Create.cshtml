@model EDUCONTROL.Models.Asignatura
@{
    ViewData["Title"] = "Nueva asignatura";
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="fw-bold mb-0">Nueva asignatura</h4>
</div>

<div class="card shadow-sm" style="max-width:480px">
    <div class="card-body p-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-semibold"></label>
                <input asp-for="Nombre" class="form-control"
                       placeholder="Ej: Matematicas" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Grado" class="form-label fw-semibold">
                    Grado (opcional)
                </label>
                <select asp-for="Grado" class="form-select">
                    <option value="">-- Todos los grados --</option>
                    @foreach (var g in new[]{"1 grado","2 grado","3 grado",
                                        "4 grado","5 grado","6 grado","7 grado","8 grado","9 grado"})
                    {
                        <option value="@g">@g</option>
                    }
                </select>
                <small class="text-muted">
                    Deja en blanco si aplica para todos los grados.
                </small>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Guardar
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}