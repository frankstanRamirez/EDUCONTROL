@using EDUCONTROL.Models
@{
    ViewData["Title"] = "Reporte de Notas";
    var detalle = ViewBag.Detalle as IEnumerable<dynamic> ?? new List<dynamic>();
    bool filtrado = ViewBag.FiltroAplicado == true;
}

<style>
    @@media print {
        .no-print, #sidebar, #topnav, .solo-pantalla {
            display: none !important;
        }

        #main {
            margin-left: 0 !important;
        }

        body {
            background: #fff;
        }

        .reporte-header {
            border-bottom: 3px solid #5cb85c; /* Color azul para Notas */
            margin-bottom: 20px;
        }

        .reporte-footer {
            border-top: 2px solid #5cb85c;
            margin-top: 40px;
            padding-top: 8px;
            font-style: italic;
            color: #555;
        }
    }

    @@media screen {
        .solo-impresion {
            display: none !important;
        }
    }

    .reporte-header {
        border-bottom: 3px solid #5cb85c;
        margin-bottom: 20px;
    }

    .reporte-footer {
        border-top: 2px solid #5cb85c;
        margin-top: 40px;
        padding-top: 8px;
        font-style: italic;
        color: #555;
    }
</style>

@* --- CABECERA DE PANTALLA --- *@
<div class="d-flex align-items-center justify-content-between mb-4 mt-4 no-print">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-file-earmark-text text-primary"></i> Reporte de Notas
    </h4>
    <div class="text-end">
        <button type="button" onclick="window.print()"
                class="btn btn-outline-success shadow-sm @(!filtrado ? "disabled" : "")">
            <i class="bi bi-printer"></i> Imprimir
        </button>
    </div>
</div>

@* --- FORMULARIO DE FILTROS --- *@
<div class="card shadow-sm border-0 mb-4 bg-light no-print">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-bold">Grado</label>
                <select name="grado" class="form-select shadow-sm" required>
                    <option value="">-- Seleccionar --</option>
                    @foreach (var g in new[] { "1 grado", "2 grado", "3 grado", "4 grado", "5 grado", "6 grado", "7 grado", "8 grado", "9 grado" })
                    {
                        <option value="@g" selected="@(ViewBag.GradoFiltro == g)">@g</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">Sección</label>
                <select name="seccion" class="form-select shadow-sm">
                    <option value="">Todas</option>
                    @foreach (var s in new[] { "A", "B", "C", "D" })
                    {
                        <option value="@s" selected="@(ViewBag.SeccionFiltro == s)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-bold">Asignatura</label>
                <select name="asignaturaId" class="form-select shadow-sm">
                    <option value="">-- Todas las materias --</option>
                    @foreach (var asig in (List<Asignatura>)ViewBag.Asignaturas)
                    {
                        <option value="@asig.Id" selected="@(ViewBag.AsigFiltro == asig.Id)">@asig.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100 shadow-sm">
                    <i class="bi bi-funnel"></i> Filtrar Reporte
                </button>
            </div>
        </form>
    </div>
</div>

@* --- VISTA PARA PANTALLA --- *@
<div class="solo-pantalla">
    @if (!filtrado)
    {
        <div class="alert alert-info border-0 shadow-sm d-flex align-items-center">
            <i class="bi bi-info-circle-fill me-2 fs-5"></i>
            <span>Selecciona un grado y haz clic en <strong>Filtrar Reporte</strong> para generar el reporte.</span>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 mb-3 p-3 bg-white">
            <div class="row g-3">
                <div class="col-md-3">
                    <small class="text-muted d-block">Grado / Curso</small>
                    <strong class="text-dark">@ViewBag.GradoFiltro</strong>
                </div>
                <div class="col-md-3">
                    <small class="text-muted d-block">Sección</small>
                    <strong class="text-dark">@(ViewBag.SeccionFiltro ?? "Todas")</strong>
                </div>
                <div class="col-md-3">
                    <small class="text-muted d-block">Promedio General</small>
                    <strong class="text-primary">@ViewBag.PromedioGeneral</strong>
                </div>
                <div class="col-md-3">
                    <small class="text-muted d-block">Docente</small>
                    <strong class="text-dark">@Context.Session.GetString("UsuarioNombre")</strong>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 overflow-hidden">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">Estudiante</th>
                        <th class="text-center">Per. 1</th>
                        <th class="text-center">Per. 2</th>
                        <th class="text-center">Per. 3</th>
                        <th class="text-center">Promedio</th>
                        <th class="text-center">Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in detalle)
                    {
                        <tr>
                            <td class="ps-3 fw-semibold">@item.NombreCompleto</td>
                            <td class="text-center">@item.Periodo1</td>
                            <td class="text-center">@item.Periodo2</td>
                            <td class="text-center">@item.Periodo3</td>
                            <td class="text-center fw-bold">@item.Promedio</td>
                            <td class="text-center">
                                <span class="badge @(item.Estado == "Aprobado" ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") border">
                                    @item.Estado
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* --- VISTA PARA IMPRESIÓN (Idéntica a Asistencia) --- *@
<div class="solo-impresion">
    <div class="reporte-header pb-2 text-center">
        @* Usamos la misma ruta de imagen que en asistencia *@
        <img src="/images/logo.png" alt="EduControl" style="height:70px;" />
        <h4 class="fw-bold mt-2 mb-0">REPORTE DE NOTAS</h4>
    </div>
    <div class="my-4" style="line-height:1.8">
        <p class="mb-1"><strong>Grado / Curso:</strong> @ViewBag.GradoFiltro</p>
        <p class="mb-1"><strong>Sección:</strong> @(ViewBag.SeccionFiltro ?? "Todas")</p>
        <p class="mb-1"><strong>Asignatura:</strong> @(ViewBag.NombreAsignatura ?? "Todas")</p>
        <p class="mb-1"><strong>Docente:</strong> @Context.Session.GetString("UsuarioNombre")</p>
        <p class="mb-1"><strong>Fecha:</strong> @DateTime.Now.ToString("dd/MM/yyyy") - @DateTime.Now.ToString("HH:mm")</p>
    </div>
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr>
                <th>Nombre del Estudiante</th>
                <th class="text-center">P1</th>
                <th class="text-center">P2</th>
                <th class="text-center">P3</th>
                <th class="text-center">Prom.</th>
                <th class="text-center">Estado</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in detalle)
            {
                <tr>
                    <td>@item.NombreCompleto</td>
                    <td class="text-center">@item.Periodo1</td>
                    <td class="text-center">@item.Periodo2</td>
                    <td class="text-center">@item.Periodo3</td>
                    <td class="text-center"><strong>@item.Promedio</strong></td>
                    <td class="text-center">@item.Estado</td>
                </tr>
            }
        </tbody>
    </table>
    <div class="reporte-footer mt-5">
        Documento generado automáticamente por el sistema de control escolar.
    </div>
</div>