@using EDUCONTROL.Models
@{
    ViewData["Title"] = "Reporte de Notas";
    bool aplicado = ViewBag.FiltroAplicado ?? false;
}

<style>
    /* Estilos para la pantalla normal */
    .header-print-only {
        display: none;
    }

    @@media print {
        /* Ocultamos todo lo innecesario */
        .no-print, #sidebar, #topnav, .row.mb-4, .card.shadow-sm.border-0.mb-4 {
            display: none !important;
        }
        /* Mostramos el encabezado de impresión */
        .header-print-only {
            display: block !important;
            text-align: center;
            margin-bottom: 20px;
        }
        /* Ajustes de tabla para papel */
        table {
            width: 100% !important;
            border: 1px solid #000 !important;
        }

        th {
            background-color: #f0f0f0 !important;
            color: #000 !important;
            border: 1px solid #000 !important;
            -webkit-print-color-adjust: exact;
        }

        td {
            border: 1px solid #ccc !important;
            padding: 5px !important;
        }

        .badge {
            border: none !important;
            padding: 0 !important;
            color: #000 !important;
            background: transparent !important;
        }
    }
</style>

@* --- ENCABEZADO EXCLUSIVO PARA IMPRESIÓN --- *@
<div class="header-print-only">
    <div class="d-flex align-items-center justify-content-center mb-2">
        @* Asegúrate de que la ruta de la imagen sea correcta *@
        <img src="/img/logo.png" style="width: 70px; height: auto;" alt="Logo" />
        <div class="ms-3 text-center">
            <h2 class="mb-0 fw-bold">EDUCONTROL</h2>
            <h4 class="mb-0">Reporte de Calificaciones</h4>
        </div>
    </div>
    <hr style="border: 1px solid #0d6efd; opacity: 1;" />

    <div class="row text-start mt-3" style="font-size: 14px;">
        <div class="col-6">
            <p class="mb-1"><strong>Grado / Curso:</strong> @ViewBag.GradoFiltro</p>
            <p class="mb-1"><strong>Sección:</strong> @(string.IsNullOrEmpty(ViewBag.SeccionFiltro) ? "Todas" : ViewBag.SeccionFiltro)</p>
        </div>
        <div class="col-6">
            <p class="mb-1"><strong>Docente:</strong> @Context.Session.GetString("UsuarioNombre")</p>
            <p class="mb-1"><strong>Fecha Generado:</strong> @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
        </div>
    </div>
</div>

@* --- CONTENIDO NORMAL DE LA VISTA --- *@
<div class="d-flex align-items-center justify-content-between mb-4 mt-4 no-print">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-file-earmark-text text-primary"></i> Reporte de Notas
    </h4>
    <div class="text-end">
        <button type="button" onclick="window.print()"
                class="btn btn-outline-success shadow-sm @(aplicado ? "" : "disabled")">
            <i class="bi bi-printer"></i> Imprimir
        </button>
    </div>
</div>

@* ... El resto de tu formulario de filtros se mantiene igual ... *@

@if (aplicado)
{
    @* ... Las tarjetas de resumen se mantienen igual (tienen no-print implícito por el CSS) ... *@

    <div class="card shadow-sm border-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">Estudiante</th>
                        <th class="text-center">Per. 1</th>
                        <th class="text-center">Per. 2</th>
                        <th class="text-center">Per. 3</th>
                        <th class="text-center">Promedio</th>
                        <th class="text-center">Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ViewBag.Detalle)
                    {
                        <tr>
                            <td class="ps-3 fw-semibold">@item.NombreCompleto</td>
                            <td class="text-center">@item.Periodo1</td>
                            <td class="text-center">@item.Periodo2</td>
                            <td class="text-center">@item.Periodo3</td>
                            <td class="text-center fw-bold">@item.Promedio</td>
                            <td class="text-center">
                                <span class="badge @(item.Estado == "Aprobado" ? "bg-success-subtle text-success" : item.Estado == "Reprobado" ? "bg-danger-subtle text-danger" : "bg-light text-dark") border">
                                    @item.Estado
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info border-0 shadow-sm d-flex align-items-center">
        <i class="bi bi-info-circle-fill me-2 fs-5"></i>
        <span>Selecciona un grado y haz clic en <strong>Filtrar Reporte</strong> para generar el reporte.</span>
    </div>
}