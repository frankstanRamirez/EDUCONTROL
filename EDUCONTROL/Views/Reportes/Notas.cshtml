@using EDUCONTROL.Models
@{
    ViewData["Title"] = "Reporte de Notas";
    bool aplicado = ViewBag.FiltroAplicado ?? false;
}

<style>
    @@media print {
        .no-print, #sidebar, #topnav, .row.mb-4 {
            display: none !important;
        }

        #main {
            margin-left: 0 !important;
        }

        body {
            background: #fff;
        }

        .reporte-header {
            border-bottom: 3px solid #0d6efd;
            margin-bottom: 20px;
        }

        .reporte-footer {
            border-top: 2px solid #0d6efd;
            margin-top: 40px;
            padding-top: 8px;
            font-style: italic;
            color: #555;
        }
    }
</style>

<div class="d-flex align-items-center justify-content-between mb-4 mt-4 no-print">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-file-earmark-text text-primary"></i> Reporte de Notas
    </h4>
    <div class="text-end">
        <button type="button" onclick="window.print()"
                class="btn btn-outline-success shadow-sm @(aplicado ? "" : "disabled")">
            <i class="bi bi-printer"></i> Imprimir
        </button>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4 bg-light no-print">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-bold">Grado</label>
                <select name="grado" class="form-select shadow-sm" required>
                    <option value="">-- Seleccionar --</option>
                    @foreach (var g in new[] { "1 grado", "2 grado", "3 grado", "4 grado", "5 grado", "6 grado", "7 grado", "8 grado", "9 grado" })
                    {
                        <option value="@g" selected="@(ViewBag.GradoFiltro == g)">@g</option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label small fw-bold">Sección</label>
                <select name="seccion" class="form-select shadow-sm">
                    <option value="">Todas</option>
                    @foreach (var s in new[] { "A", "B", "C", "D" })
                    {
                        <option value="@s" selected="@(ViewBag.SeccionFiltro == s)">@s</option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label small fw-bold">Asignatura</label>
                <select name="asignaturaId" class="form-select shadow-sm">
                    <option value="">-- Todas las materias --</option>
                    @foreach (var asig in (List<Asignatura>)ViewBag.Asignaturas)
                    {
                        <option value="@asig.Id" selected="@(ViewBag.AsigFiltro == asig.Id)">@asig.Nombre</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100 shadow-sm">
                    <i class="bi bi-funnel"></i> Filtrar Reporte
                </button>
            </div>
        </form>
    </div>
</div>

@if (aplicado)
{
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white text-center p-3 border-0 shadow-sm">
                <div class="small opacity-75">Estudiantes</div>
                <div class="h3 mb-0">@ViewBag.TotalEstudiantes</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white text-center p-3 border-0 shadow-sm">
                <div class="small opacity-75">Promedio Gral.</div>
                <div class="h3 mb-0">@ViewBag.PromedioGeneral</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white text-center p-3 border-0 shadow-sm">
                <div class="small opacity-75">Aprobados</div>
                <div class="h3 mb-0">@ViewBag.Aprobados</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white text-center p-3 border-0 shadow-sm">
                <div class="small opacity-75">Reprobados</div>
                <div class="h3 mb-0">@ViewBag.Reprobados</div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">Estudiante</th>
                        <th class="text-center">Per. 1</th>
                        <th class="text-center">Per. 2</th>
                        <th class="text-center">Per. 3</th>
                        <th class="text-center">Promedio</th>
                        <th class="text-center">Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ViewBag.Detalle)
                    {
                        <tr>
                            <td class="ps-3 fw-semibold">@item.NombreCompleto</td>
                            <td class="text-center">@item.Periodo1</td>
                            <td class="text-center">@item.Periodo2</td>
                            <td class="text-center">@item.Periodo3</td>
                            <td class="text-center fw-bold">@item.Promedio</td>
                            <td class="text-center">
                                <span class="badge @(item.Estado == "Aprobado" ? "bg-success-subtle text-success" : item.Estado == "Reprobado" ? "bg-danger-subtle text-danger" : "bg-light text-dark") border">
                                    @item.Estado
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info border-0 shadow-sm d-flex align-items-center">
        <i class="bi bi-info-circle-fill me-2 fs-5"></i>
        <span>Selecciona un grado y haz clic en <strong>Filtrar Reporte</strong> para generar el reporte.</span>
    </div>
}