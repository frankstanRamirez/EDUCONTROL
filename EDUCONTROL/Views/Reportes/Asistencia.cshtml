@using EDUCONTROL.Models
@{
    ViewData["Title"] = "Reporte de Asistencia";
    var detalle = ViewBag.Detalle as IEnumerable<dynamic> ?? new List<dynamic>();
    bool filtrado = ViewBag.FiltroAplicado == true;
}

<style>
    @@media print {
        .no-print, #sidebar, #topnav, .solo-pantalla {
            display: none !important;
        }

        #main {
            margin-left: 0 !important;
        }

        body {
            background: #fff;
        }

        .reporte-header {
            border-bottom: 3px solid #5cb85c;
            margin-bottom: 20px;
        }

        .reporte-footer {
            border-top: 2px solid #5cb85c;
            margin-top: 40px;
            padding-top: 8px;
            font-style: italic;
            color: #555;
        }
    }

    @@media screen {
        .solo-impresion {
            display: none !important;
        }
    }

    .reporte-header {
        border-bottom: 3px solid #5cb85c;
        margin-bottom: 20px;
    }

    .reporte-footer {
        border-top: 2px solid #5cb85c;
        margin-top: 40px;
        padding-top: 8px;
        font-style: italic;
        color: #555;
    }
</style>

<div class="d-flex align-items-center justify-content-between mb-4 mt-4 no-print">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-file-earmark-bar-graph text-primary"></i> Reporte de Asistencia
    </h4>
    <div class="text-end">
        <button type="button" onclick="window.print()"
                class="btn btn-outline-success shadow-sm @(!filtrado ? "disabled" : "")">
            <i class="bi bi-printer"></i> Imprimir
        </button>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4 bg-light no-print">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-bold">Grado</label>
                <select name="grado" class="form-select shadow-sm" required>
                    <option value="">-- Seleccionar --</option>
                    @foreach (var g in new[] { "1 grado", "2 grado", "3 grado", "4 grado", "5 grado", "6 grado", "7 grado", "8 grado", "9 grado" })
                    {
                        <option value="@g" selected="@(ViewBag.GradoFiltro == g)">@g</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">Sección</label>
                <select name="seccion" class="form-select shadow-sm">
                    <option value="">Todas</option>
                    @foreach (var s in new[] { "A", "B", "C", "D" })
                    {
                        <option value="@s" selected="@(ViewBag.SeccionFiltro == s)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-bold">Fecha</label>
                <input type="date" name="fecha" value="@ViewBag.FechaFiltro" class="form-control shadow-sm" />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100 shadow-sm">
                    <i class="bi bi-funnel"></i> Filtrar Reporte
                </button>
            </div>
        </form>
    </div>
</div>

<div class="solo-pantalla">
    @if (!filtrado)
    {
        <div class="alert alert-info border-0 shadow-sm d-flex align-items-center">
            <i class="bi bi-info-circle-fill me-2 fs-5"></i>
            <span>Selecciona un grado y haz clic en <strong>Filtrar Reporte</strong> para ver los datos.</span>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 mb-3 p-3 bg-white">
            <div class="row g-3">
                <div class="col-md-3">
                    <small class="text-muted d-block">Grado / Curso</small>
                    <strong class="text-dark">@ViewBag.GradoFiltro</strong>
                </div>
                <div class="col-md-3">
                    <small class="text-muted d-block">Sección</small>
                    <strong class="text-dark">@(ViewBag.SeccionFiltro ?? "Todas")</strong>
                </div>
                <div class="col-md-3">
                    <small class="text-muted d-block">Fecha reporte</small>
                    <strong class="text-dark">@ViewBag.FechaReporte</strong>
                </div>
                <div class="col-md-3">
                    <small class="text-muted d-block">Docente</small>
                    <strong class="text-dark">@ViewBag.Docente</strong>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 overflow-hidden">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Nombre del Estudiante</th>
                        <th class="text-center text-info">Asistencias</th>
                        <th class="text-center text-danger">Ausencias</th>
                        <th class="text-center text-warning">Tardías</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int n = 1;
                    }
                    @foreach (var f in detalle)
                    {
                        <tr>
                            <td class="ps-3">@n</td>
                            <td class="fw-semibold">@f.NombreCompleto</td>
                            <td class="text-center text-success fw-bold">@f.Asistencias</td>
                            <td class="text-center text-danger fw-bold">@f.Ausencias</td>
                            <td class="text-center text-warning fw-bold">@f.Tardias</td>
                        </tr>
                        n++;
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-4 d-flex flex-wrap gap-4 p-2 bg-light rounded shadow-sm">
            <span class="fw-bold">Total Estudiantes: <span class="badge bg-secondary">@ViewBag.TotalEstudiantes</span></span>
            <span class="text-success fw-bold">Presentes: @ViewBag.TotalPresentes</span>
            <span class="text-danger fw-bold">Ausentes: @ViewBag.TotalAusentes</span>
            <span class="text-warning fw-bold">Tardanzas: @ViewBag.TotalTardanzas</span>
        </div>
    }
</div>

<div class="solo-impresion">
    <div class="reporte-header pb-2 text-center">
        <img src="/images/logo.png" alt="EduControl" style="height:70px;" />
        <h4 class="fw-bold mt-2 mb-0">REPORTE DE ASISTENCIA</h4>
    </div>
    <div class="my-4" style="line-height:1.8">
        <p class="mb-1"><strong>Grado / Curso:</strong> @ViewBag.GradoFiltro</p>
        <p class="mb-1"><strong>Sección:</strong> @(ViewBag.SeccionFiltro ?? "Todas")</p>
        <p class="mb-1"><strong>Docente:</strong> @ViewBag.Docente</p>
        <p class="mb-1"><strong>Fecha:</strong> @ViewBag.FechaReporte - @ViewBag.HoraReporte</p>
    </div>
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr>
                <th style="width:40px">Nº</th>
                <th>Nombre</th>
                <th class="text-center">Asistencias</th>
                <th class="text-center">Ausencias</th>
                <th class="text-center">Tardías</th>
            </tr>
        </thead>
        <tbody>
            @{
                int np = 1;
            }
            @foreach (var f in detalle)
            {
                <tr>
                    <td class="text-center">@np</td>
                    <td>@f.NombreCompleto</td>
                    <td class="text-center">@f.Asistencias</td>
                    <td class="text-center">@f.Ausencias</td>
                    <td class="text-center">@f.Tardias</td>
                </tr>
                np++;
            }
        </tbody>
    </table>
    <div class="reporte-footer mt-5">
        Documento generado automáticamente por el sistema de control escolar.
    </div>
</div>