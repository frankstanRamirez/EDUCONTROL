@{
    ViewData["Title"] = "Reporte de Asistencia";
    var detalle = ViewBag.Detalle as IEnumerable<dynamic> ?? new List<dynamic>();
}

<style>
    /* ── Lo que se oculta al imprimir ── */
    @@media print {
        .no-print {
            display: none !important;
        }

        #sidebar, #topnav {
            display: none !important;
        }

        #main {
            margin-left: 0 !important;
        }

        body {
            background: #fff;
        }

        .solo-pantalla {
            display: none !important;
        }

        .reporte-header {
            border-bottom: 3px solid #5cb85c;
            margin-bottom: 20px;
        }

        .reporte-footer {
            border-top: 2px solid #5cb85c;
            margin-top: 40px;
            padding-top: 8px;
            font-style: italic;
            color: #555;
        }
    }

    /* ── Lo que se oculta en pantalla ── */
    @@media screen {
        .solo-impresion {
            display: none !important;
        }
    }

    .reporte-header {
        border-bottom: 3px solid #5cb85c;
        margin-bottom: 20px;
    }

    .reporte-footer {
        border-top: 2px solid #5cb85c;
        margin-top: 40px;
        padding-top: 8px;
        font-style: italic;
        color: #555;
    }
</style>

<div class="no-print mb-4">
    <div class="d-flex align-items-center mb-3 gap-2">
        <h4 class="fw-bold mb-0">
            <i class="bi bi-file-earmark-bar-graph text-primary"></i> Reporte de Asistencia
        </h4>
    </div>
    <form method="get" class="row g-2">
        <div class="col-md-3">
            <select name="grado" class="form-select">
                <option value="">-- Seleccionar grado --</option>
                @foreach (var g in new[] { "1 grado", "2 grado", "3 grado", "4 grado", "5 grado", "6 grado", "7 grado", "8 grado", "9 grado" })
                {
                    <option value="@g" selected="@(ViewBag.GradoFiltro == g)">@g</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <input type="date" name="fecha" value="@ViewBag.FechaFiltro" class="form-control" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Filtrar</button>
        </div>
        <div class="col-md-2">
            <button type="button" onclick="window.print()" class="btn btn-success w-100">
                <i class="bi bi-printer"></i> Imprimir
            </button>
        </div>
    </form>
</div>

<div class="solo-pantalla">
    @if (detalle.Any())
    {
        <div class="card shadow-sm mb-3 p-3" style="max-width:700px">
            <div class="row g-2">
                <div class="col-md-6">
                    <span class="text-muted">Grado / Curso:</span>
                    <strong class="ms-2">@(ViewBag.GradoFiltro ?? "—")</strong>
                </div>
                <div class="col-md-6">
                    <span class="text-muted">Docente:</span>
                    <strong class="ms-2">@ViewBag.Docente</strong>
                </div>
                <div class="col-md-6">
                    <span class="text-muted">Fecha Reporte:</span>
                    <strong class="ms-2">@ViewBag.FechaReporte</strong>
                </div>
            </div>
        </div>

        <div class="card shadow-sm" style="max-width:900px">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Nombre del Estudiante</th>
                        <th class="text-center">Asistencias</th>
                        <th class="text-center">Ausencias</th>
                        <th class="text-center">Tardías</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int num = 1;
                    }
                    @foreach (var f in detalle)
                    {
                        <tr>
                            <td>@num</td>
                            <td>@f.NombreCompleto</td>
                            <td class="text-center text-success fw-bold">@f.Asistencias</td>
                            <td class="text-center text-danger fw-bold">@f.Ausencias</td>
                            <td class="text-center text-warning fw-bold">@f.Tardias</td>
                        </tr>
                        num++;
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3 d-flex gap-4">
            <span>Total: <strong>@ViewBag.TotalEstudiantes</strong></span>
            <span class="text-success">Presentes: <strong>@ViewBag.TotalPresentes</strong></span>
            <span class="text-danger">Ausentes: <strong>@ViewBag.TotalAusentes</strong></span>
            <span class="text-warning">Tardanzas: <strong>@ViewBag.TotalTardanzas</strong></span>
        </div>
    }
    else
    {
        <div class="alert alert-info mt-3">
            <i class="bi bi-info-circle"></i> Selecciona grado y fecha, luego haz clic en <strong>Filtrar</strong>.
        </div>
    }
</div>

<div class="solo-impresion" style="max-width:900px">
    <div class="reporte-header pb-2">
        <div class="text-center">
            <img src="/images/logo.png" alt="EduControl" style="height:70px;width:auto;" />
        </div>
        <h4 class="fw-bold text-center mt-2 mb-0">REPORTE DE ASISTENCIA</h4>
    </div>

    <div class="mb-4" style="line-height:2">
        <p class="mb-1"><strong>Grado / Curso:</strong> @ViewBag.GradoFiltro</p>
        <p class="mb-1"><strong>Docente:</strong> @ViewBag.Docente</p>
        <p class="mb-1"><strong>Fecha de Consulta:</strong> @ViewBag.FechaFiltro</p>
        <p class="mb-1"><strong>Generado el:</strong> @ViewBag.FechaReporte a las @ViewBag.HoraReporte</p>
    </div>

    <p class="fw-semibold mb-1">DETALLE POR ESTUDIANTE</p>
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr>
                <th style="width:40px">Nº</th>
                <th>Nombre del Estudiante</th>
                <th class="text-center">Asistencias</th>
                <th class="text-center">Ausencias</th>
                <th class="text-center">Tardías</th>
            </tr>
        </thead>
        <tbody>
            @{
                int numP = 1;
            }
            @foreach (var f in detalle)
            {
                <tr>
                    <td class="text-center">@numP</td>
                    <td>@f.NombreCompleto</td>
                    <td class="text-center">@f.Asistencias</td>
                    <td class="text-center">@f.Ausencias</td>
                    <td class="text-center">@f.Tardias</td>
                </tr>
                numP++;
            }
        </tbody>
    </table>

    <div class="mt-4">
        <p class="fw-bold mb-2">RESUMEN DE ASISTENCIA</p>
        <p class="mb-1"><strong>Total estudiantes:</strong> @ViewBag.TotalEstudiantes</p>
        <p class="mb-1"><strong>Total Presentes:</strong> @ViewBag.TotalPresentes</p>
        <p class="mb-1"><strong>Total Ausentes:</strong> @ViewBag.TotalAusentes</p>
        <p class="mb-1"><strong>Total Tardanzas:</strong> @ViewBag.TotalTardanzas</p>
    </div>

    <div class="reporte-footer mt-5">
        Documento generado automáticamente por el sistema de control escolar.
    </div>
</div>