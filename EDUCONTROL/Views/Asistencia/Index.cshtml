@{
    ViewData["Title"] = "Módulo de Asistencia";
    var rol = Context.Session.GetString("UsuarioRol") ?? "";
}

<div class="container-fluid mt-4">
    <h4 class="fw-bold mb-4">
        <i class="bi bi-calendar-check text-primary"></i> Módulo de Asistencia
    </h4>



    <div class="row g-4 justify-content-center">
        <div class="@(rol == "Profesor" ? "col-md-7" : "col-md-5")">
            <div class="card shadow-sm border-0 h-100 transition-hover">
                <div class="card-body p-5 text-center d-flex flex-column align-items-center justify-content-center">
                    <i class="bi bi-plus-circle text-primary mb-3" style="font-size:3.5rem"></i>
                    <h5 class="fw-bold">Registrar Asistencia</h5>
                    <p class="text-muted mb-4">Marca la asistencia diaria de los estudiantes del grado.</p>
                    <a asp-action="Registrar" class="btn btn-primary w-100 py-2 shadow-sm">
                        <i class="bi bi-pencil-fill me-1"></i> Ir a registrar
                    </a>
                </div>
            </div>
        </div>

        @if (rol != "Profesor")
        {
            <div class="col-md-5">
                <div class="card shadow-sm border-0 h-100 transition-hover">
                    <div class="card-body p-5 text-center d-flex flex-column align-items-center justify-content-center">
                        <i class="bi bi-search text-success mb-3" style="font-size:3.5rem"></i>
                        <h5 class="fw-bold">Consultar Asistencia</h5>
                        <p class="text-muted mb-4">Revisa y filtra los registros por fecha y grado.</p>
                        <a asp-action="Consultar" class="btn btn-success w-100 py-2 shadow-sm">
                            <i class="bi bi-eye-fill me-1"></i> Ir a consultar
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s;
        border-radius: 15px;
    }

        .transition-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
</style>