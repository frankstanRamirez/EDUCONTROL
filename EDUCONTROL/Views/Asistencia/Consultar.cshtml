@model IEnumerable<EDUCONTROL.Models.Asistencia>
@{
    ViewData["Title"] = "Consultar Asistencia";
    // Identificamos el rol para cambiar la interfaz
    bool esDirector = ViewBag.EsAdminOSecretaria == true;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="fw-bold mb-0">Consultar Asistencia</h2>
    <a asp-action="Registrar" class="btn btn-primary shadow-sm" style="border-radius: 10px;">
        <i class="bi bi-plus-circle me-1"></i> + Registrar asistencia
    </a>
</div>

@* --- PANEL DE FILTROS HÍBRIDO --- *@
<div class="card border-0 shadow-sm mb-4" style="background-color: #f8f9fa; border-radius: 15px;">
    <div class="card-body p-3">
        <form method="get" class="row g-3 align-items-end">

            @if (esDirector)
            {
                @* VISTA PARA DIRECTOR: Selectores con estilo de Píldora *@
                <div class="col-md-3">
                    <label class="small fw-bold text-muted d-block mb-1 text-uppercase">Grado</label>
                    <div class="input-group bg-white shadow-sm border" style="border-radius: 25px; overflow: hidden; height: 45px;">
                        <span class="input-group-text bg-white border-0 pe-1"><i class="bi bi-mortarboard text-primary"></i></span>
                        <select name="grado" class="form-select border-0 fw-bold" style="box-shadow: none; font-size: 0.9rem;">
                            <option value="">Seleccionar Grado</option>
                            @foreach (var g in new[] { "1 grado", "2 grado", "3 grado", "4 grado", "5 grado", "6 grado", "7 grado", "8 grado", "9 grado" })
                            {
                                <!option value="@g" @(ViewBag.GradoFiltro == g ? "selected" : "")>@g</!option>
                            }
                        </select>
                    </div>
                </div>

                <div class="col-md-2">
                    <label class="small fw-bold text-muted d-block mb-1 text-uppercase">Sección</label>
                    <div class="input-group bg-white shadow-sm border" style="border-radius: 25px; overflow: hidden; height: 45px;">
                        <span class="input-group-text bg-white border-0 pe-1"><i class="bi bi-collection text-primary"></i></span>
                        <select name="seccion" class="form-select border-0 fw-bold text-primary" style="box-shadow: none; font-size: 0.9rem;">
                            <option value="">Sec</option>
                            @foreach (var s in new[] { "A", "B", "C", "D" })
                            {
                                <!option value="@s" @(ViewBag.SeccionFiltro == s ? "selected" : "")>@s</!option>
                            }
                        </select>
                    </div>
                </div>
            }
            else
            {
                @* VISTA PARA PROFESOR: Se mantiene el diseño original de "Mi Sección" *@
                <div class="col-md-4">
                    <label class="small fw-bold text-muted d-block mb-1 text-uppercase">Mi Sección</label>
                    <div class="bg-white d-flex align-items-center px-3 shadow-sm border" style="border-radius: 25px; height: 45px;">
                        <i class="bi bi-people-fill text-primary me-2"></i>
                        <span class="fw-bold text-dark">@ViewBag.GradoFiltro "@ViewBag.SeccionFiltro"</span>
                    </div>
                </div>
            }

            @* Selector de Fecha (Estilo Píldora para ambos) *@
            <div class="col-md-3">
                <label class="small fw-bold text-muted d-block mb-1 text-uppercase">Fecha de Consulta</label>
                <div class="input-group bg-white shadow-sm border" style="border-radius: 25px; overflow: hidden; height: 45px;">
                    <span class="input-group-text bg-white border-0 pe-1"><i class="bi bi-calendar-event text-primary"></i></span>
                    <input type="date" name="fecha" class="form-control border-0 fw-bold"
                           value="@(ViewBag.FechaFiltro ?? DateTime.Now.ToString("yyyy-MM-dd"))" style="box-shadow: none; font-size: 0.9rem;" />
                </div>
            </div>

            @* Botones de Acción: Ajustados a la altura de los inputs *@
            <div class="col-md-auto ms-auto d-flex gap-2">
                <button type="submit" class="btn btn-dark px-4 shadow-sm" style="border-radius: 12px; height: 45px;">
                    <i class="bi bi-funnel me-1"></i> Filtrar
                </button>
                <a asp-action="Consultar" class="btn btn-outline-secondary shadow-sm d-flex align-items-center justify-content-center" style="border-radius: 12px; width: 45px; height: 45px;">
                    <i class="bi bi-arrow-clockwise"></i>
                </a>
            </div>
        </form>
    </div>
</div>

@* --- TABLA DE RESULTADOS (ESTILO NOTAS) --- *@
<div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead style="background-color: #f8f9fa;">
                <tr class="text-muted small">
                    <th class="ps-4 text-uppercase">Fecha</th>
                    <th class="text-uppercase">Alumno</th>
                    <th class="text-center text-uppercase">Grado/Sec</th>
                    <th class="text-center text-uppercase">Estado</th>
                    <th class="pe-4 text-uppercase">Registrado por</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var a in Model)
                    {
                        <tr style="border-bottom: 1px solid #f2f2f2;">
                            <td class="ps-4 text-muted" style="font-size: 0.9rem;">@a.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="fw-bold text-dark" style="font-size: 0.95rem;">
                                    @a.Alumno?.NombreCompleto
                                </div>
                                <div class="text-muted small" style="font-size: 0.8rem;">
                                    NIE: @a.Alumno?.NIE
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="text-muted" style="font-size: 0.9rem;">@a.Alumno?.Grado - @a.Alumno?.Seccion</span>
                            </td>
                            <td class="text-center">
                                @if (a.Estado == "Presente")
                                {
                                    <span class="badge rounded-pill bg-success px-3 py-2" style="font-size: 0.75rem; min-width: 90px;">
                                        <i class="bi bi-check-circle-fill me-1"></i> Presente
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-danger px-3 py-2" style="font-size: 0.75rem; min-width: 90px;">
                                        <i class="bi bi-x-circle-fill me-1"></i> Ausente
                                    </span>
                                }
                            </td>
                            <td class="pe-4 text-muted small">
                                @a.RegistradoPor
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="bi bi-search fs-2 d-block mb-2"></i>
                            No hay registros. Seleccione los filtros para buscar.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>