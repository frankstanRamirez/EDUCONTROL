@{
    ViewData["Title"] = "Registrar Asistencia";
    var alumnos = ViewBag.Alumnos as List<EDUCONTROL.Models.Alumno>;
    bool esAdmin = ViewBag.EsAdmin == true;
    string gradoActual = ViewBag.Grado ?? "";
    string seccionActual = ViewBag.Seccion ?? "";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm" style="border-radius: 10px;">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h2 class="fw-bold mb-0">
            <i class="bi bi-calendar-check text-primary"></i> Registrar Asistencia
        </h2>
        <span class="badge bg-secondary">@gradoActual</span>
        @if (!string.IsNullOrEmpty(seccionActual))
        {
            <span class="badge bg-success">Sección @seccionActual</span>
        }
    </div>
</div>

@* --- FILTROS: Solo para Director/Secretaria --- *@
@if (esAdmin)
{
    <div class="card border-0 shadow-sm mb-4" style="background-color: #f8f9fa; border-radius: 15px;">
        <div class="card-body p-3">
            <form method="get" class="row g-3 align-items-end">

                <div class="col-md-3">
                    <label class="small fw-bold text-muted d-block mb-1 text-uppercase">Grado</label>
                    <div class="input-group bg-white shadow-sm border" style="border-radius: 25px; overflow: hidden; height: 45px;">
                        <span class="input-group-text bg-white border-0 pe-1">
                            <i class="bi bi-mortarboard text-primary"></i>
                        </span>
                        <select name="grado" class="form-select border-0 fw-bold" style="box-shadow: none; font-size: 0.9rem;">
                            <option value="">-- Todos los grados --</option>
                            @foreach (var g in new[] { "1 grado", "2 grado", "3 grado", "4 grado", "5 grado", "6 grado", "7 grado", "8 grado", "9 grado" })
                            {
                                if (gradoActual == g)
                                {
                                    <option value="@g" selected>@g</option>
                                }
                                else
                                {
                                    <option value="@g">@g</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="col-md-2">
                    <label class="small fw-bold text-muted d-block mb-1 text-uppercase">Sección</label>
                    <div class="input-group bg-white shadow-sm border" style="border-radius: 25px; overflow: hidden; height: 45px;">
                        <span class="input-group-text bg-white border-0 pe-1">
                            <i class="bi bi-collection text-primary"></i>
                        </span>
                        <select name="seccion" class="form-select border-0 fw-bold text-primary" style="box-shadow: none; font-size: 0.9rem;">
                            <option value="">-- Todas --</option>
                            @foreach (var s in new[] { "A", "B", "C", "D" })
                            {
                                if (seccionActual == s)
                                {
                                    <option value="@s" selected>@s</option>
                                }
                                else
                                {
                                    <option value="@s">@s</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="col-md-auto">
                    <button type="submit" class="btn btn-primary px-4 shadow-sm" style="border-radius: 12px; height: 45px;">
                        <i class="bi bi-search me-1"></i> Cargar Alumnos
                    </button>
                </div>

            </form>
        </div>
    </div>
}

<form method="post" asp-action="Registrar">
    @Html.AntiForgeryToken()

    @* --- FECHA --- *@
    <div class="card border-0 shadow-sm mb-4" style="background-color: #f8f9fa; border-radius: 15px; max-width: 320px;">
        <div class="card-body p-3">
            <label class="small fw-bold text-muted d-block mb-1 text-uppercase">Fecha de asistencia</label>
            <div class="input-group bg-white shadow-sm border" style="border-radius: 25px; overflow: hidden; height: 45px;">
                <span class="input-group-text bg-white border-0 pe-1">
                    <i class="bi bi-calendar-event text-primary"></i>
                </span>
                <input type="date" name="fecha" value="@ViewBag.Fecha" class="form-control border-0 fw-bold"
                       style="box-shadow: none; font-size: 0.9rem;" required />
            </div>
        </div>
    </div>

    @* --- TABLA --- *@
    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead style="background-color: #f8f9fa;">
                    <tr class="text-muted small">
                        <th class="ps-4 text-uppercase">#</th>
                        <th class="text-uppercase">NIE</th>
                        <th class="text-uppercase">Nombre del Estudiante</th>
                        <th class="text-center text-uppercase">Presente</th>
                        <th class="text-center text-uppercase">Ausente</th>
                        <th class="text-center text-uppercase">Tardanza</th>
                    </tr>
                </thead>
                <tbody>
                    @if (alumnos != null && alumnos.Any())
                    {
                        @for (int i = 0; i < alumnos.Count; i++)
                        {
                            <tr style="border-bottom: 1px solid #f2f2f2;">
                                <input type="hidden" name="alumnoIds" value="@alumnos[i].Id" />
                                <td class="ps-4 text-muted" style="font-size: 0.9rem;">@(i + 1)</td>
                                <td class="fw-bold text-primary" style="font-size: 0.95rem;">@alumnos[i].NIE</td>
                                <td class="fw-semibold text-dark" style="font-size: 0.95rem;">@alumnos[i].NombreCompleto</td>
                                <td class="text-center">
                                    <input type="radio" class="form-check-input border-success"
                                           name="estado_@alumnos[i].Id" value="Presente" checked />
                                </td>
                                <td class="text-center">
                                    <input type="radio" class="form-check-input border-danger"
                                           name="estado_@alumnos[i].Id" value="Ausente" />
                                </td>
                                <td class="text-center">
                                    <input type="radio" class="form-check-input border-warning"
                                           name="estado_@alumnos[i].Id" value="Tardanza" />
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-people fs-2 d-block mb-2"></i>
                                @if (esAdmin)
                                {
                                    <span>Selecciona un grado y sección para cargar la lista.</span>
                                }
                                else
                                {
                                    <span>No se encontraron alumnos en <strong>@gradoActual "@seccionActual"</strong>.</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (alumnos != null && alumnos.Any())
    {
        <div class="mt-4 p-3 bg-light rounded d-flex justify-content-between align-items-center" style="border-radius: 12px !important;">
            <span class="text-muted small">Total de alumnos en lista: <strong>@alumnos.Count</strong></span>
            <div class="d-flex gap-2">
                <a asp-action="Consultar" class="btn btn-outline-secondary shadow-sm" style="border-radius: 10px;">
                    <i class="bi bi-list-ul me-1"></i> Ver Historial
                </a>
                <button type="submit" class="btn btn-success px-4 shadow-sm" style="border-radius: 10px;">
                    <i class="bi bi-save me-1"></i> Guardar Asistencia
                </button>
            </div>
        </div>
    }

</form>