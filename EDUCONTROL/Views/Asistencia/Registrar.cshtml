@{
    ViewData["Title"] = "Registrar Asistencia";
    var alumnos = ViewBag.Alumnos as List<EDUCONTROL.Models.Alumno>;
    bool esAdmin = ViewBag.EsAdmin == true;
}

<div class="d-flex align-items-center mb-3 gap-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="fw-bold mb-0">
        <i class="bi bi-calendar-check text-primary"></i> Registrar Asistencia
    </h4>
    <span class="badge bg-secondary">@ViewBag.Grado</span>
    @if (!string.IsNullOrEmpty(ViewBag.Seccion as string))
    {
        <span class="badge bg-info text-dark">Sección @ViewBag.Seccion</span>
    }
</div>

<!-- Filtro de grado y sección (solo Director/Secretaria) -->
@if (esAdmin)
{
    <form method="get" class="row g-2 mb-4">
        <div class="col-md-3">
            <select name="grado" class="form-select">
                <option value="">-- Todos los grados --</option>
                @foreach (var g in new[]{"1 grado","2 grado","3 grado","4 grado",
                                        "5 grado","6 grado","7 grado","8 grado","9 grado"})
                {
                    <option value="@g" selected="@(ViewBag.Grado == g)">@g</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="seccion" class="form-select">
                <option value="">-- Sección --</option>
                @foreach (var s in new[] { "A", "B", "C", "D" })
                {
                    <option value="@s" selected="@(ViewBag.Seccion == s)">@s</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-primary w-100">
                <i class="bi bi-funnel"></i> Filtrar
            </button>
        </div>
    </form>
}

<form method="post" asp-action="Registrar">
    @Html.AntiForgeryToken()
    <div class="mb-3" style="max-width:220px">
        <label class="form-label fw-semibold">Fecha</label>
        <input type="date" name="fecha" value="@ViewBag.Fecha"
               class="form-control" required />
    </div>
    <div class="card shadow-sm">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>NIE</th>
                    <th>Nombre</th>
                    <th class="text-center">Presente</th>
                    <th class="text-center">Ausente</th>
                    <th class="text-center">Tardanza</th>
                </tr>
            </thead>
            <tbody>
                @if (alumnos != null && alumnos.Any())
                {
                    @for (int i = 0; i < alumnos.Count; i++)
                    {
                        <tr>
                            <input type="hidden" name="alumnoIds" value="@alumnos[i].Id" />
                            <td>@(i + 1)</td>
                            <td class="text-danger fw-semibold">@alumnos[i].NIE</td>
                            <td>@alumnos[i].NombreCompleto</td>

                            <td class="text-center">
                                <input type="radio" name="estado_@alumnos[i].Id" value="Presente" />
                            </td>
                            <td class="text-center">
                                <input type="radio" name="estado_@alumnos[i].Id" value="Ausente" />
                            </td>
                            <td class="text-center">
                                <input type="radio" name="estado_@alumnos[i].Id" value="Tardanza" />
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-3">
                            @if (esAdmin)
                            {
                                <span>Selecciona un grado arriba para cargar alumnos.</span>
                            }
                            else
                            {

                                <span>No hay alumnos activos en tu grado asignado.</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (alumnos != null && alumnos.Any())
    {
        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-success">
                <i class="bi bi-save"></i> Guardar asistencia
            </button>
            <a asp-action="Consultar" class="btn btn-outline-secondary">
                Ver registros
            </a>
        </div>
    }
</form>