@{
    ViewData["Title"] = "Registrar Asistencia";
    var alumnos = ViewBag.Alumnos as List<EDUCONTROL.Models.Alumno>;
    bool esAdmin = ViewBag.EsAdmin == true;
}

<div class="d-flex align-items-center mb-3 gap-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="fw-bold mb-0">
        <i class="bi bi-calendar-check text-primary"></i> Registrar Asistencia
    </h4>

    @* Etiquetas de info para que el Profe sepa qué está pasando *@
    <span class="badge bg-secondary">@ViewBag.Grado</span>
    @if (!string.IsNullOrEmpty(ViewBag.Seccion as string))
    {
        <span class="badge bg-success">Sección @ViewBag.Seccion</span>
    }
</div>

@* --- FILTROS: Solo para el Jefe (Director/Secretaria) --- *@
@if (esAdmin)
{
    <div class="card bg-light border-0 mb-4">
        <div class="card-body">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="small fw-bold text-muted">Grado</label>
                    <select name="grado" class="form-select">
                        <option value="">-- Todos los grados --</option>
                        @foreach (var g in new[] { "1 grado", "2 grado", "3 grado", "4 grado", "5 grado", "6 grado", "7 grado", "8 grado", "9 grado" })
                        {
                            <option value="@g" selected="@(ViewBag.Grado == g)">@g</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="small fw-bold text-muted">Sección</label>
                    <select name="seccion" class="form-select">
                        <option value="">-- Todas --</option>
                        @foreach (var s in new[] { "A", "B", "C", "D" })
                        {
                            <option value="@s" selected="@(ViewBag.Seccion == s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Cargar Alumnos
                    </button>
                </div>
            </form>
        </div>
    </div>
}

<form method="post" asp-action="Registrar">
    @Html.AntiForgeryToken()

    <div class="mb-4 d-flex align-items-end gap-3" style="max-width:400px">
        <div>
            <label class="form-label fw-semibold">Fecha de asistencia</label>
            <input type="date" name="fecha" value="@ViewBag.Fecha" class="form-control" required />
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">#</th>
                        <th>NIE</th>
                        <th>Nombre del Estudiante</th>
                        <th class="text-center">Presente</th>
                        <th class="text-center">Ausente</th>
                        <th class="text-center">Tardanza</th>
                    </tr>
                </thead>
                <tbody>
                    @if (alumnos != null && alumnos.Any())
                    {
                        @for (int i = 0; i < alumnos.Count; i++)
                        {
                            <tr>
                                <input type="hidden" name="alumnoIds" value="@alumnos[i].Id" />
                                <td class="ps-3 text-muted">@(i + 1)</td>
                                <td class="fw-bold text-primary">@alumnos[i].NIE</td>
                                <td class="fw-semibold">@alumnos[i].NombreCompleto</td>

                                <td class="text-center">
                                    <input type="radio" class="form-check-input border-success" name="estado_@alumnos[i].Id" value="Presente" checked />
                                </td>
                                <td class="text-center">
                                    <input type="radio" class="form-check-input border-danger" name="estado_@alumnos[i].Id" value="Ausente" />
                                </td>
                                <td class="text-center">
                                    <input type="radio" class="form-check-input border-warning" name="estado_@alumnos[i].Id" value="Tardanza" />
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <i class="bi bi-people text-muted" style="font-size: 2rem;"></i>
                                <p class="mb-0 mt-2 text-muted">
                                    @if (esAdmin)
                                    {
                                        <span>Selecciona un grado y sección para cargar la lista.</span>
                                    }
                                    else
                                    {
                                        <span>No se encontraron alumnos registrados en <strong>@ViewBag.Grado "@ViewBag.Seccion"</strong>.</span>
                                    }
                                </p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (alumnos != null && alumnos.Any())
    {
        <div class="mt-4 p-3 bg-light rounded d-flex justify-content-between align-items-center">
            <span class="text-muted small">Total de alumnos en lista: <strong>@alumnos.Count</strong></span>
            <div class="d-flex gap-2">
                <a asp-action="Consultar" class="btn btn-outline-secondary">
                    <i class="bi bi-list-ul"></i> Ver Historial
                </a>
                <button type="submit" class="btn btn-success px-4 shadow-sm">
                    <i class="bi bi-save"></i> Guardar Asistencia
                </button>
            </div>
        </div>
    }
</form>