@{
    ViewData["Title"] = "Registrar Asistencia";
    var alumnos = ViewBag.Alumnos as List<EDUCONTROL.Models.Alumno>;
}
<div class="d-flex align-items-center mb-4 gap-3">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-calendar-check text-primary"></i> Registrar Asistencia
    </h4>
    <span class="badge bg-secondary">@ViewBag.Grado</span>
</div>
<form method="post" asp-action="Registrar">
    @Html.AntiForgeryToken()
    <div class="mb-3" style="max-width:220px">
        <label class="form-label fw-semibold">Fecha</label>
        <input type="date" name="fecha" value="@ViewBag.Fecha"
               class="form-control" required />
    </div>
    <div class="card shadow-sm">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>NIE</th>
                    <th>Nombre</th>
                    <th class="text-center">Presente</th>
                    <th class="text-center">Ausente</th>
                    <th class="text-center">Tardanza</th>
                </tr>
            </thead>
            <tbody>
                @if (alumnos != null)
                {
                    @for (int i = 0; i < alumnos.Count; i++)
                    {
                        <tr>
                            <input type="hidden" name="alumnoIds" value="@alumnos[i].Id" />
                            <td>@(i + 1)</td>
                            <td><code>@alumnos[i].NIE</code></td>
                            <td>@alumnos[i].NombreCompleto</td>

                            <td class="text-center">
                                @* Quitamos el 'checked' para que aparezca vacío *@
                                <input type="radio" name="estado_@alumnos[i].Id" value="Presente" required />
                            </td>
                            <td class="text-center">
                                <input type="radio" name="estado_@alumnos[i].Id" value="Ausente" required />
                            </td>
                            <td class="text-center">
                                <input type="radio" name="estado_@alumnos[i].Id" value="Tardanza" required />
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-success">
            <i class="bi bi-save"></i> Guardar asistencia
        </button>
        <a asp-action="Consultar" class="btn btn-outline-secondary">Ver registros</a>
    </div>
</form>